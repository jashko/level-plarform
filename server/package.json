{
  "name": "level-platform-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LEVEL Platform — Express API backend",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "pipeline:cbr": "tsx -e \"import('./src/services/dataPipeline.js').then(m => m.runPipeline('cbr_fetch'))\"",
    "pipeline:cities": "tsx -e \"import('./src/services/dataPipeline.js').then(m => m.runPipeline('city_update'))\"",
    "pipeline:validate": "tsx -e \"import('./src/services/validation.js').then(m => m.validateAllCities())\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "compression": "^1.8.0",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.6.1",
    "bullmq": "^5.34.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.25.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  }
}
