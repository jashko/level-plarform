{
  "name": "level-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LEVEL Group — аналитическая платформа для скоринга городов, участков и финансового моделирования жилых проектов",
  "scripts": {
    "example": "tsx src/engine/finance/example.ts",
    "scores": "tsx scripts/compute-scores.ts",
    "fetch-cbr": "tsx scripts/fetch-cbr.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "esbuild src/engine/index.ts --bundle --format=esm --outfile=ui/engine.js --target=es2020 --loader:.json=json && esbuild src/app.js --bundle --format=esm --outfile=ui/app.js --target=es2020 --loader:.json=json --define:process.env.NODE_ENV=\\\"production\\\" --minify --platform=browser",
    "ui": "npm run fetch-cbr && npm run bundle && npx --yes serve ui -l 3000",
    "agent": "tsx scripts/data-agent.ts"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  }
}
